<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>
  <%- include('partials/page-banner', {
    image: assets.nayabIntroBanner,
    eyebrow: 'About',
    title: "Hello, I'm Nayab",
    lead: 'Your personal psychotherapist and counselor — dedicated, culturally attuned, clinically grounded.'
  }) %>

  <section class="section about-intro-visual">
    <div class="container about-promo-row">
      <figure class="about-promo-main">
        <%- include('partials/img', {
          src: assets.nayabAbout,
          alt: 'Nayab Tahir — Registered Psychotherapist',
          className: 'about-photo'
        }) %>
      </figure>
      <figure class="about-promo-side">
        <%- include('partials/img', {
          src: assets.nayabPromoVertical,
          fallback: assets.nayabIntroBanner,
          alt: 'Psychotherapy services with Nayab Tahir',
          className: 'promo-vertical-img'
        }) %>
      </figure>
    </div>
  </section>

  <%- include('partials/video-section', {
    heading: 'Videos from Nayab',
    subheading: 'Learn more about my approach, Voice Awareness, and how we can work together.',
    showCta: true
  }) %>

  <section class="section">
    <div class="container content-grid">
      <div class="content-main prose">
        <%- page.html || '' %>
      </div>
      <aside class="sidebar">
        <div class="sidebar-card sidebar-photo">
          <%- include('partials/img', {
            src: assets.brandingIcon,
            alt: 'Mental health support symbol',
            className: 'sidebar-img contain-img'
          }) %>
        </div>
        <div class="sidebar-card">
          <h3>Credentials</h3>
          <ul class="check-list">
            <li>MACP — Yorkville University</li>
            <li>BA Psychology</li>
            <li>BSc Pharmacy</li>
            <li>Registered Psychotherapist (Ontario)</li>
          </ul>
        </div>
        <div class="sidebar-card">
          <h3>Connect</h3>
          <ul class="link-list">
            <li><a href="<%= site.youtube %>" target="_blank" rel="noopener">YouTube</a></li>
            <li><a href="<%= site.linkedin %>" target="_blank" rel="noopener">LinkedIn</a></li>
            <li><a href="<%= site.psychologyToday %>" target="_blank" rel="noopener">Psychology Today</a></li>
            <li><a href="<%= site.janeApp %>" target="_blank" rel="noopener">Jane App</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <section class="section alt">
    <div class="container center">
      <figure class="healing-icon-large">
        <%- include('partials/img', {
          src: assets.healingGrowthIcon,
          alt: 'Healing and personal growth',
          className: 'healing-icon-img'
        }) %>
      </figure>
      <p class="lead">You don't have to go through it alone. I'm here to walk with you.</p>
    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>

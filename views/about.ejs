<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body class="page-about">
  <%- include('partials/header') %>
  <%- include('partials/page-banner', {
    image: assets.aboutBanner,
    title: 'Nayab Tahir',
    lead: 'Counselor — Dedicated, Culturally Attuned, Clinically Grounded.',
    bannerClass: 'page-banner--about'
  }) %>

  <section class="section about-main">
    <div class="container content-grid about-content-grid">
      <div class="content-main about-content-main">
        <div class="prose">
          <%- page.html || '' %>
        </div>
        <div class="about-closing">
          <figure class="about-closing-icon">
            <%- include('partials/img', {
              src: assets.healingGrowthIcon,
              alt: 'Healing and personal growth',
              className: 'healing-icon-img'
            }) %>
          </figure>
          <p class="lead about-closing-text">You don't have to go through it alone. I'm here to walk with you.</p>
        </div>
      </div>
      <aside class="sidebar">
        <div class="sidebar-card sidebar-photo">
          <%- include('partials/img', {
            src: assets.brandingIcon,
            alt: 'Mental health support symbol',
            className: 'sidebar-img contain-img'
          }) %>
        </div>
        <div class="sidebar-card">
          <h3>Credentials</h3>
          <ul class="check-list">
            <li>MACP — Yorkville University</li>
            <li>BA Psychology</li>
            <li>BSc Pharmacy</li>
            <li>Registered Psychotherapist (Ontario)</li>
          </ul>
        </div>
        <div class="sidebar-card">
          <h3>Connect</h3>
          <ul class="link-list">
            <li><a href="<%= site.youtube %>" target="_blank" rel="noopener">YouTube</a></li>
            <li><a href="<%= site.linkedin %>" target="_blank" rel="noopener">LinkedIn</a></li>
            <li><a href="<%= site.psychologyToday %>" target="_blank" rel="noopener">Psychology Today</a></li>
            <li><a href="<%= site.janeApp %>" target="_blank" rel="noopener">Jane App</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>

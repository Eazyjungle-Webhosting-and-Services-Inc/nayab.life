<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>
  <%- include('partials/page-banner', {
    image: assets.aboutBanner,
    eyebrow: 'About',
    title: "Hello, I'm Nayab",
    lead: 'Your personal psychotherapist and counselor — dedicated, culturally attuned, clinically grounded.'
  }) %>
  <section class="section">
    <div class="container content-grid">
      <div class="content-main prose">
        <figure class="inline-portrait">
          <%- include('partials/img', {
            src: assets.heroPortrait,
            fallback: assets.heroPortraitFallback,
            alt: 'Nayab Tahir portrait',
            className: 'rounded-photo'
          }) %>
        </figure>
        <%- page.html || '' %>
      </div>
      <aside class="sidebar">
        <div class="sidebar-card sidebar-photo">
          <%- include('partials/img', {
            src: assets.therapySession,
            fallback: assets.therapySessionFallback,
            alt: 'Therapeutic conversation',
            className: 'sidebar-img'
          }) %>
        </div>
        <div class="sidebar-card">
          <h3>Credentials</h3>
          <ul class="check-list">
            <li>MACP — Yorkville University</li>
            <li>BA Psychology</li>
            <li>BSc Pharmacy</li>
            <li>Registered Psychotherapist (Ontario)</li>
          </ul>
        </div>
        <div class="sidebar-card">
          <h3>Connect</h3>
          <ul class="link-list">
            <li><a href="<%= site.youtube %>" target="_blank" rel="noopener">YouTube</a></li>
            <li><a href="<%= site.linkedin %>" target="_blank" rel="noopener">LinkedIn</a></li>
            <li><a href="<%= site.psychologyToday %>" target="_blank" rel="noopener">Psychology Today</a></li>
            <li><a href="<%= site.janeApp %>" target="_blank" rel="noopener">Jane App</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
  <%- include('partials/footer') %>
</body>
</html>

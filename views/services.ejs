<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>
  <%- include('partials/page-banner', {
    image: assets.servicesBanner,
    eyebrow: 'Services',
    title: 'Psychotherapy & counseling for adults',
    lead: 'Evidence-based, trauma-informed care tailored to your unique situation and goals.'
  }) %>
  <section class="section">
    <div class="container prose">
      <%- page.html || '' %>
    </div>
  </section>
  <section class="section gallery-row">
    <div class="container gallery-three">
      <figure>
        <%- include('partials/img', { src: assets.mindfulness, fallback: assets.mindfulnessFallback, alt: 'Mindfulness', className: 'gallery-img' }) %>
      </figure>
      <figure>
        <%- include('partials/img', { src: assets.therapySession, fallback: assets.therapySessionFallback, alt: 'Therapy session', className: 'gallery-img' }) %>
      </figure>
      <figure>
        <%- include('partials/img', { src: assets.calmNature, fallback: assets.calmNatureFallback, alt: 'Calm reflection', className: 'gallery-img' }) %>
      </figure>
    </div>
  </section>
  <section class="section alt">
    <div class="container narrow center">
      <h2>Who counseling is for</h2>
      <p class="lead">You do not need to be in crisis to begin therapy. Many clients seek support proactively for growth, balance, and emotional well-being.</p>
      <a href="<%= site.janeApp %>" class="btn btn-primary" target="_blank" rel="noopener">Book a free consultation</a>
    </div>
  </section>
  <%- include('partials/footer') %>
</body>
</html>

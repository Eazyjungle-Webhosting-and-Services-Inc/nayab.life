<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body class="page-home">
  <%- include('partials/header') %>

  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-shapes" aria-hidden="true">
      <span class="shape shape-1"></span>
      <span class="shape shape-2"></span>
      <span class="shape shape-3"></span>
    </div>
    <div class="container hero-grid">
      <div class="hero-content">
        <p class="eyebrow">
          <a href="<%= site.companyUrl %>" target="_blank" rel="noopener">Voice Awareness Psychotherapy Services Inc.</a>
        </p>
        <h1>Find your inner peace with <em>compassionate</em> psychotherapy</h1>
        <p class="lead">
          Welcome to nayab.life — insights, articles, and developments in psychotherapy from
          <strong>Nayab Tahir</strong>, Registered Psychotherapist in Ontario.
        </p>
        <div class="hero-actions">
          <a href="<%= site.janeApp %>" class="btn btn-primary" target="_blank" rel="noopener">Book a consultation</a>
          <a href="/about" class="btn btn-glass">Meet Nayab</a>
          <a href="#videos" class="btn btn-outline">Watch videos</a>
        </div>
        <div class="hero-stats">
          <div><strong>MACP</strong><span>Counselling Psychology</span></div>
          <div><strong>5+</strong><span>Countries lived</span></div>
          <div><strong>IFS</strong><span>Certified approaches</span></div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="portrait-frame">
          <%- include('partials/img', {
            src: assets.nayabIntroBanner,
            fallback: assets.heroPortraitFallback,
            alt: 'Nayab Tahir, Registered Psychotherapist',
            className: 'hero-portrait',
            loading: 'eager'
          }) %>
        </div>
        <div class="hero-badge">
          <span>IFS · CBT · DBT</span>
          <span>Trauma-informed care</span>
        </div>
      </div>
    </div>
  </section>

  <section class="visual-strip pillars-section" aria-label="Therapeutic focus areas">
    <!-- deploy-marker: pillars-v11 -->
    <div class="container">
      <div class="visual-strip-track pillars-grid">
        <figure class="pillar-card pillar-card--sage">
          <%- include('partials/img', { src: assets.therapySession, fallback: assets.therapySessionFallback, alt: 'Collaborative Therapy', className: 'strip-img' }) %>
          <figcaption class="pillar-overlay">
            <span class="pillar-label">Together in care</span>
            <strong class="pillar-caption">Collaborative Therapy</strong>
            <p class="pillar-desc">A client-led space where your voice, pace, and goals shape every session.</p>
          </figcaption>
        </figure>
        <figure class="pillar-card pillar-card--lavender">
          <%- include('partials/img', { src: assets.mindfulness, fallback: assets.mindfulnessFallback, alt: 'Mindfulness Balance', className: 'strip-img' }) %>
          <figcaption class="pillar-overlay">
            <span class="pillar-label">Calm &amp; grounded</span>
            <strong class="pillar-caption">Mindfulness Balance</strong>
            <p class="pillar-desc">Nervous-system-focused practices that restore clarity, presence, and inner steadiness.</p>
          </figcaption>
        </figure>
        <figure class="pillar-card pillar-card--peach">
          <%- include('partials/img', { src: assets.calmNature, fallback: assets.calmNatureFallback, alt: 'Emotional Wellness', className: 'strip-img' }) %>
          <figcaption class="pillar-overlay">
            <span class="pillar-label">Heal &amp; grow</span>
            <strong class="pillar-caption">Emotional Wellness</strong>
            <p class="pillar-desc">Compassionate support to understand emotions, build resilience, and feel whole again.</p>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <%- include('partials/promo-gallery') %>

  <%- include('partials/video-section', { showCta: true }) %>

  <section class="section intro-strip">
    <div class="container intro-grid">
      <blockquote>
        Therapy is not about quick fixes — it is a collaborative process focused on self-awareness,
        coping skills, and long-term emotional well-being.
      </blockquote>
      <div>
        <p>
          Through <a href="<%= site.companyUrl %>">Voice Awareness</a>, Nayab offers evidence-based,
          trauma-informed psychotherapy for adults navigating anxiety, trauma, relationship challenges,
          and life transitions.
        </p>
        <a href="/approach" class="btn btn-outline">Explore my approach</a>
      </div>
    </div>
  </section>

  <section class="section services-preview" id="areas-of-focus">
    <div class="container">
      <header class="section-header section-header--stacked">
        <p class="section-eyebrow">Services</p>
        <h2>Areas of focus</h2>
        <p class="section-lead">Personalized care grounded in clinical expertise and cross-cultural understanding.</p>
      </header>
      <div class="card-grid four service-cards">
        <article class="service-card service-card--stress" style="--card-accent: #1a6b5c">
          <div class="service-card-img">
            <%- include('partials/img', { src: assets.serviceStress, fallback: assets.serviceStressFallback, alt: 'Woman meditating at home with her dog for calm and stress relief', className: 'service-card-photo' }) %>
            <span class="service-card-tag">Calm &amp; balance</span>
          </div>
          <div class="service-card-body">
            <h3>Stress Management</h3>
            <p>Personalized sessions to alleviate pressures and restore purpose and balance.</p>
          </div>
        </article>
        <article class="service-card service-card--relationship" style="--card-accent: #6b4a8a">
          <div class="service-card-img">
            <%- include('partials/img', { src: assets.serviceRelationship, fallback: assets.serviceRelationshipFallback, alt: 'Hands gently working through tangled red thread—a metaphor for untangling relationship trauma', className: 'service-card-photo' }) %>
            <span class="service-card-tag">Connection &amp; safety</span>
          </div>
          <div class="service-card-body">
            <h3>Relationship Trauma</h3>
            <p>Process complex experiences and rebuild safety in individual or couples work.</p>
          </div>
        </article>
        <article class="service-card service-card--emotional" style="--card-accent: #2a6b8a">
          <div class="service-card-img">
            <%- include('partials/img', { src: assets.serviceEmotional, fallback: assets.serviceEmotionalFallback, alt: 'Silhouette meditating at golden sunset—calm and emotional balance', className: 'service-card-photo' }) %>
            <span class="service-card-tag">Regulation &amp; clarity</span>
          </div>
          <div class="service-card-body">
            <h3>Emotional Stability</h3>
            <p>Learn regulation skills when emotions feel intensely high or low.</p>
          </div>
        </article>
        <article class="service-card service-card--growth" style="--card-accent: #8a6b2a">
          <div class="service-card-img">
            <%- include('partials/img', { src: assets.serviceGrowth, fallback: assets.serviceGrowthFallback, alt: 'Creative growth and personal development', className: 'service-card-photo' }) %>
            <span class="service-card-tag">Growth &amp; purpose</span>
          </div>
          <div class="service-card-body">
            <h3>Personal Growth</h3>
            <p>Identify roadblocks and nurture self-awareness for lasting change.</p>
          </div>
        </article>
      </div>
      <p class="section-cta"><a href="/services" class="btn btn-text">View all services →</a></p>
    </div>
  </section>

  <section class="section about-teaser">
    <div class="container about-teaser-grid">
      <div class="about-teaser-img">
        <%- include('partials/img', {
          src: assets.nayabAbout,
          alt: 'Nayab Tahir',
          className: 'about-photo'
        }) %>
      </div>
      <div>
        <p class="eyebrow">About Nayab</p>
        <h2>Hello, I'm Nayab</h2>
        <p>Registered Psychotherapist with a Master's in Counselling Psychology (MACP), cross-cultural lived experience across five countries, and a passion for breaking mental health stigma.</p>
        <ul class="check-list">
          <li>Trauma-informed &amp; evidence-based care</li>
          <li>Virtual sessions across Ontario</li>
          <li>Collaborative, client-led therapy</li>
        </ul>
        <a href="/about" class="btn btn-primary">Read my story</a>
      </div>
    </div>
  </section>

  <% if (latestBlog && latestBlog.length) { %>
  <section class="section alt">
    <div class="container">
      <header class="section-header">
        <h2>From the blog</h2>
        <a href="/blog" class="btn btn-text">All posts</a>
      </header>
      <div class="card-grid three">
        <% latestBlog.forEach(function(post) { %>
          <%- include('partials/post-card', { post: post, type: 'blog' }) %>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <% if (latestNews && latestNews.length) { %>
  <section class="section">
    <div class="container">
      <header class="section-header">
        <h2>News &amp; developments</h2>
        <a href="/news" class="btn btn-text">All news</a>
      </header>
      <div class="card-grid three">
        <% latestNews.forEach(function(post) { %>
          <%- include('partials/post-card', { post: post, type: 'news' }) %>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <section class="section cta-band">
    <div class="cta-band-bg" aria-hidden="true"></div>
    <div class="container cta-inner">
      <div>
        <h2>Ready to take the next step?</h2>
        <p>Book a free consultation or explore therapeutic approaches that honour your pace and goals.</p>
      </div>
      <div class="cta-actions">
        <a href="<%= site.janeApp %>" class="btn btn-primary" target="_blank" rel="noopener">Jane App</a>
        <a href="/contact" class="btn btn-glass">Contact</a>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>

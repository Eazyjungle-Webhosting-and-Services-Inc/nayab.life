<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { metaDescription: post.metaDescription || post.excerpt }) %>
</head>
<body>
  <%- include('partials/header') %>
  <% const bannerImg = post.featuredImage || assets.defaultPost; %>
  <%- include('partials/page-banner', {
    image: bannerImg,
    eyebrow: typeLabel,
    title: post.title,
    lead: post.excerpt
  }) %>
  <article class="section">
    <div class="container narrow">
      <p class="post-meta">
        <time datetime="<%= post.publishedAt %>">
          <%= new Date(post.publishedAt || post.createdAt).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' }) %>
        </time>
        <% if (post.author) { %> · <%= post.author %><% } %>
      </p>
      <div class="prose"><%- post.html %></div>
      <% if (post.tags && post.tags.length) { %>
        <ul class="tag-list">
          <% post.tags.forEach(function(tag) { %><li><%= tag %></li><% }); %>
        </ul>
      <% } %>
      <p class="post-back"><a href="/<%= type %>" class="btn btn-outline">← Back to <%= typeLabel %></a></p>
    </div>
  </article>
  <%- include('partials/footer') %>
</body>
</html>

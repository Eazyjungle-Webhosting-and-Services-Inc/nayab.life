<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>
  <%- include('partials/page-banner', {
    image: assets.mindfulness,
    eyebrow: typeLabel,
    title: title,
    lead: 'Insights and updates from Nayab Tahir on psychotherapy and mental wellness.'
  }) %>
  <section class="section">
    <div class="container">
      <% if (!posts.length) { %>
        <p class="empty-state">No published <%= typeLabel.toLowerCase() %> yet. Check back soon.</p>
      <% } else { %>
        <div class="card-grid three">
          <% posts.forEach(function(post) { %>
            <%- include('partials/post-card', { post: post, type: type }) %>
          <% }); %>
        </div>
      <% } %>
    </div>
  </section>
  <%- include('partials/footer') %>
</body>
</html>

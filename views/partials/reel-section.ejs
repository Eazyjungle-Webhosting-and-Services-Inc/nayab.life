<section class="section reel-section" id="reels">
  <div class="container">
    <header class="section-header center-header">
      <p class="eyebrow">Reels</p>
      <h2><%= typeof heading !== 'undefined' ? heading : 'Mental wellness insights' %></h2>
      <p class="lead section-lead"><%= typeof subheading !== 'undefined' ? subheading : 'Short reflections on overthinking, productivity, and finding peace — from Nayab Tahir.' %></p>
    </header>
    <div class="reel-stage">
      <article class="reel-phone">
        <div class="reel-phone-notch" aria-hidden="true"></div>
        <video
          class="reel-player"
          controls
          preload="metadata"
          playsinline
          poster="<%= asset(assets.reelClip3Poster) %>"
          aria-label="<%= assets.reelClip3Title %>"
        >
          <source src="<%= asset(assets.reelClip3) %>" type="video/mp4" />
          Your browser does not support embedded video.
        </video>
      </article>
      <div class="reel-sidecopy">
        <h3><%= assets.reelClip3Title %></h3>
        <p><%= assets.reelClip3Description %></p>
        <ul class="check-list">
          <li>Intro &amp; branding</li>
          <li>Nayab on overthinking &amp; inner peace</li>
          <li>Therapy imagery &amp; booking call-to-action</li>
        </ul>
        <a href="<%= site.janeApp %>" class="btn btn-primary" target="_blank" rel="noopener">Book a consultation</a>
      </div>
    </div>
  </div>
</section>

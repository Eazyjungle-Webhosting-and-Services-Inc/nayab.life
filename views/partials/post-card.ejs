<% const cardImg = post.featuredImage || assets.defaultPost; %>
<article class="post-card">
  <a href="/<%= type %>/<%= post.slug %>" class="post-card-image">
    <%- include('img', {
      src: cardImg,
      fallback: assets.mindfulnessFallback,
      alt: post.title,
      className: 'post-card-img'
    }) %>
    <span class="post-card-overlay"></span>
  </a>
  <div class="post-card-body">
    <time datetime="<%= post.publishedAt || post.createdAt %>">
      <%= new Date(post.publishedAt || post.createdAt).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' }) %>
    </time>
    <h3><a href="/<%= type %>/<%= post.slug %>"><%= post.title %></a></h3>
    <p><%= post.excerpt %></p>
    <a href="/<%= type %>/<%= post.slug %>" class="read-more">Read more</a>
  </div>
</article>

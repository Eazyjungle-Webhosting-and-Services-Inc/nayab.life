<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Nayab Tahir home">
      <%- include('img', { src: assets.logo, fallback: assets.logoFallback, alt: 'Voice Awareness', className: 'logo-img', loading: 'eager' }) %>
      <span class="logo-text">
        <strong>Nayab Tahir</strong>
        <small>Psychotherapy &amp; Insight</small>
      </span>
    </a>
    <button class="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <nav class="main-nav" aria-label="Main">
      <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Home</a>
      <a href="/about" class="<%= currentPath === '/about' ? 'active' : '' %>">About</a>
      <a href="/services" class="<%= currentPath === '/services' ? 'active' : '' %>">Services</a>
      <a href="/approach" class="<%= currentPath === '/approach' ? 'active' : '' %>">Approach</a>
      <a href="/blog" class="<%= currentPath.startsWith('/blog') ? 'active' : '' %>">Blog</a>
      <a href="/articles" class="<%= currentPath.startsWith('/articles') ? 'active' : '' %>">Articles</a>
      <a href="/news" class="<%= currentPath.startsWith('/news') ? 'active' : '' %>">News</a>
      <a href="/about#videos" class="<%= currentPath === '/about' ? 'active' : '' %>">Videos</a>
      <a href="/about#reels" class="">Reels</a>
      <a href="/contact" class="nav-cta <%= currentPath === '/contact' ? 'active' : '' %>">Connect</a>
    </nav>
  </div>
</header>
